{
  "name": "cicara-vscode-git-commit-message-generator",
  "version": "0.0.2",
  "description": "AI-powered Git commit message generator using DeepSeek — analyze staged changes and generate meaningful commit messages with one click",
  "icon": "icon.png",
  "keywords": [
    "git",
    "commit",
    "commit-message",
    "ai",
    "deepseek",
    "generator",
    "scm"
  ],
  "homepage": "https://github.com/hungtcs/git-commit-message-generator#readme",
  "bugs": {
    "url": "https://github.com/hungtcs/git-commit-message-generator/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hungtcs/git-commit-message-generator.git"
  },
  "license": "MIT",
  "author": "hungtcs <hungtcs@outlook.com> (https://github.com/hungtcs)",
  "type": "module",
  "main": "./dist/extension.cjs",
  "scripts": {
    "vscode:prepublish": "npm run build",
    "build": "tsdown",
    "watch": "tsc -watch -p ./",
    "test": "vscode-test",
    "pack": "vsce package --no-dependencies"
  },
  "dependencies": {
    "@cicara/git-commit-message-generator": "^0.0.0",
    "@genkit-ai/compat-oai": "^1.36.0",
    "genkit": "^1.36.0"
  },
  "devDependencies": {
    "@types/node": "^22.19.20",
    "@types/vscode": "^1.120.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^3.0.0",
    "typescript": "^6.0.3"
  },
  "engines": {
    "vscode": "^1.120.0"
  },
  "displayName": "Cicara Git Commit Message Generator",
  "publisher": "hungtcs",
  "categories": [
    "AI",
    "SCM Providers"
  ],
  "extensionDependencies": [
    "vscode.git"
  ],
  "contributes": {
    "configuration": {
      "title": "Git Commit Message Generator",
      "properties": {
        "git-commit-message-generator.provider": {
          "type": "string",
          "default": "deepseek",
          "enum": [
            "deepseek"
          ],
          "enumDescriptions": [
            "DeepSeek V4 系列模型"
          ],
          "description": "AI 服务提供商"
        },
        "git-commit-message-generator.customInstructions": {
          "type": "string",
          "default": "",
          "markdownDescription": "生成提交信息时使用的自定义用户 prompt。配置后会替换默认用户 prompt。"
        },
        "git-commit-message-generator.customInstructionsFile": {
          "type": "string",
          "default": "",
          "markdownDescription": "生成提交信息时读取的自定义用户 prompt 文件路径。支持绝对路径，或相对于当前 Git 仓库根目录的路径。"
        }
      }
    },
    "outputChannels": [
      {
        "id": "git-commit-message-generator",
        "label": "Git Commit Message Generator",
        "languageId": "log"
      }
    ],
    "commands": [
      {
        "command": "git-commit-message-generator.generate",
        "title": "生成提交信息",
        "icon": "$(sparkle)"
      },
      {
        "command": "git-commit-message-generator.setApiKey",
        "title": "设置 DeepSeek API Key",
        "icon": "$(key)"
      }
    ],
    "menus": {
      "scm/title": [
        {
          "command": "git-commit-message-generator.generate",
          "group": "navigation",
          "when": "scmProvider == git"
        }
      ]
    }
  }
}
